# ============================================
# WhatsApp Business API (Meta)
# ============================================
# App ID de tu app en developers.facebook.com
WHATSAPP_APP_ID=1475318460751526

# Business ID de tu Meta Business Portfolio
WHATSAPP_BUSINESS_ID=937092239238837

# Phone Number ID del número (de prueba o producción)
WHATSAPP_PHONE_NUMBER_ID=1016855364854755

# WhatsApp Business Account ID (WABA)
WHATSAPP_BUSINESS_ACCOUNT_ID=4561360980855259

# Access Token (24h temporal o System User permanente)
WHATSAPP_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxx

# Verify token - inventa un string aleatorio cualquiera
# Lo usas para configurar el webhook en Meta
WHATSAPP_VERIFY_TOKEN=frutaskelly_webhook_2026_xyz

# App Secret (para verificar firma de webhook - opcional pero recomendado)
WHATSAPP_APP_SECRET=tu_app_secret_aqui

# ============================================
# Claude AI (Anthropic)
# ============================================
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxx

# Modelo a usar (opus 4.6 = mejor calidad, sonnet = balance, haiku = más rápido/barato)
CLAUDE_MODEL=claude-sonnet-4-6

# ============================================
# Configuración general
# ============================================
# Puerto local
PORT=5000

# Modo: development o production
ENVIRONMENT=production

# Numero del cliente EHMO (whitelist - solo procesa de este número)
# Formato: solo dígitos con código país, sin + ni espacios
EHMO_PHONE=521961xxxxxxx

# ============================================
# Rutas de archivos (en producción Render usa /tmp)
# ============================================
INBOX_DIR=storage/inbox
CONVERSATIONS_DIR=storage/conversations

# ============================================
# Google Drive — sube los archivos recibidos a una carpeta (OAuth user)
# ============================================
# ID de la carpeta destino (de la URL: drive.google.com/drive/folders/<ESTE_ID>)
GOOGLE_DRIVE_FOLDER_ID=
# JSON descargado del OAuth Client ID (Desktop app) de Google Cloud Console
GOOGLE_OAUTH_CREDENTIALS=secrets/google-oauth-credentials.json
# Token generado por `python -m app.drive_setup` (no editar manualmente)
GOOGLE_OAUTH_TOKEN=secrets/google-drive-token.json

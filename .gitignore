# ⚠️ Repo privado, pero secrets se manejan ENCRIPTADOS (Fernet/AES-128).
# Los .env y secrets/*.json crudos NUNCA se commitean — solo sus .enc.
# La llave de cifrado vive FUERA del repo (../.frutaskelly_secrets.key).

# Archivos sensibles en CLARO (NO commitear)
.env
.env.local
.env.production
*.env
!.env.example
!*.env.enc
!.env.enc

# Llave de cifrado (vive FUERA del repo, defensivo por si la copian dentro)
*.key
.frutaskelly_secrets.key

# Credenciales OAuth en CLARO (los .enc sí se commitean)
secrets/*.json
!secrets/*.json.enc

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/
.venv

# IDEs
.vscode/*
!.vscode/settings.json
!.vscode/launch.json
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs locales (efímeros, regenerables)
*.log
logs/

# Distribution
dist/
build/
*.egg-info/

# Backups locales
backups/

# Storage efímero (regenerable)
storage/inbox/*
!storage/inbox/.gitkeep
storage/conversations/*
!storage/conversations/.gitkeep
storage/processed/*
!storage/processed/.gitkeep
storage/raw_webhooks/

# Logs de eventos y mensajes — pueden crecer mucho
storage/event_log.jsonl
storage/message_log.jsonl

# ====================================================================
# Lo que SÍ se commitea:
#   - .env.enc, secrets/*.json.enc (credenciales encriptadas)
#   - data/Lista_Precios_EHMO.xlsx
#   - storage/keywords.json
#   - storage/clientes.json
#   - storage/folio_counter*.json
#   - storage/pedidos_dia/*.json
#   - storage/extras_dia/*.json
#   - tools/secrets_crypto.py (script de encriptado)
# ====================================================================
